generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  STORE_ADMIN
}

model Store {
  id          Int      @id @default(autoincrement())
  name        String
  domain      String   @unique // The subdomain or custom domain (e.g., fashion.localhost or myfashion.com)
  themeColor  String   @default("#000000")
  logoUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users         User[]
  categories    Category[]
  subCategories SubCategory[]
  products      Product[]
  heroImages    HeroSliderImage[]
  coupons       Coupon[]
  orders        Order[]
  settings      Setting[]
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String   // Hashed password
  role      Role     @default(STORE_ADMIN)
  storeId   Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store     Store?   @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model Category {
  id            Int           @id @default(autoincrement())
  storeId       Int
  name          String
  slug          String
  store         Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  products      Product[]
  subCategories SubCategory[]
  
  @@unique([storeId, slug])
}

model SubCategory {
  id          Int        @id @default(autoincrement())
  storeId     Int
  categoryId  Int
  name        String
  slug        String     
  store       Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category    Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  products    Product[]
  
  @@unique([storeId, slug])
}

model Product {
  id            Int             @id @default(autoincrement())
  storeId       Int
  categoryId    Int
  subCategoryId Int?
  name          String
  description   String          @db.Text
  actualPrice   Float
  sellingPrice  Float
  stock         Int             @default(0)
  isVisible     Boolean         @default(true)
  isTrending    Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  store         Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category      Category        @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  subCategory   SubCategory?    @relation(fields: [subCategoryId], references: [id], onDelete: SetNull)
  images        ProductImage[]
  orderItems    OrderItem[]
  wishlists     Wishlist[]
}

model ProductImage {
  id          Int      @id @default(autoincrement())
  productId   Int
  url         String
  isPrimary   Boolean  @default(false)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model HeroSliderImage {
  id        Int      @id @default(autoincrement())
  storeId   Int
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model Coupon {
  id             Int      @id @default(autoincrement())
  storeId        Int
  code           String   
  discountType   String   // "PERCENTAGE" or "FIXED"
  discountValue  Float
  minCartValue   Float    @default(0)
  maxDiscountCap Float?
  usageLimit     Int      @default(0) // 0 means unlimited
  timesUsed      Int      @default(0)
  expiryDate     DateTime?
  isActive       Boolean  @default(true)
  orders         Order[]
  
  store          Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  
  @@unique([storeId, code])
}

model Order {
  id               Int         @id @default(autoincrement())
  storeId          Int
  customerName     String
  customerPhone    String
  customerAddress  String      @db.Text
  totalAmount      Float
  discountAmount   Float       @default(0)
  couponId         Int?
  orderStatus      String      @default("PENDING") // PENDING, COMPLETED, CANCELLED
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  
  store            Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  coupon           Coupon?     @relation(fields: [couponId], references: [id], onDelete: SetNull)
  items            OrderItem[]
}

model OrderItem {
  id            Int      @id @default(autoincrement())
  orderId       Int
  productId     Int
  quantity      Int      @default(1)
  priceAtTime   Float
  
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Wishlist {
  id          Int      @id @default(autoincrement())
  userSession String   // Identifier for guest users
  productId   Int
  createdAt   DateTime @default(now())
  
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userSession, productId])
}

model Setting {
  id      Int    @id @default(autoincrement())
  storeId Int
  key     String 
  value   String
  
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  
  @@unique([storeId, key])
}
